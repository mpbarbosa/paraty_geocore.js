{
  "entryPoints": ["src/index.ts"],
  "out": "docs/api",                // output directory for generated HTML docs
  "name": "paraty_geocore.js",
  "readme": "README.md",            // embed README as the docs landing page
  "includeVersion": true,           // show package version in the docs title bar
  "excludePrivate": true,           // omit private class members from docs
  "excludeInternal": true,          // omit @internal-tagged symbols from docs
  "hideGenerator": true,            // remove "Generated by TypeDoc" footer
  "validation": {
    "notExported": false            // suppress warnings for internal symbols that are not re-exported from index.ts
  },
  "blockTags": ["@param", "@returns", "@throws", "@example", "@since", "@author", "@see", "@module", "@template", "@deprecated", "@pure", "@immutable", "@constant"],  // JSDoc block tags TypeDoc should recognise
  "modifierTags": ["@internal", "@override", "@static", "@class", "@extends", "@private", "@constructor", "@license"],  // tags that alter visibility or rendering behaviour
  "navigationLinks": {
    "GitHub": "https://github.com/mpbarbosa/paraty_geocore.js"
  }
}
